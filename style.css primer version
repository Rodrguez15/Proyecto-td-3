*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:#f5f5f5;
}

/* Barra superior */

.navbar{
    display:flex;
    justify-content:space-between;
    align-items:center;

    padding:15px 40px;

    background:white;

    border-bottom:1px solid #ddd;
}

.nav-links a{
    text-decoration:none;
    color:black;
    margin-right:20px;
}

.logo{
    font-weight:bold;
    color:#b30000;
}

/* Contenedor central */

.container{

    width:100%;
    min-height:85vh;

    display:flex;
    justify-content:center;
    align-items:center;
}

.card{

    width:420px;

    background:white;

    padding:30px;

    border-radius:10px;

    box-shadow:0 0 15px rgba(0,0,0,0.1);
}

.card h1{
    text-align:center;
    margin-bottom:10px;
}

.card p{
    text-align:center;
    margin-bottom:20px;
}

label{
    display:block;
    margin-top:12px;
}

input{
    width:100%;
    padding:10px;
    margin-top:5px;
}

button{
    width:100%;
    margin-top:20px;
    padding:12px;

    border:none;

    background:#b30000;
    color:white;

    cursor:pointer;
}

button:hover{
    background:#8a0000;
}

.footer-text{
    text-align:center;
    margin-top:20px;
    color:gray;
    font-size:12px;
}
